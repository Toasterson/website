---
layout: layout.njk
---

<article class="space-y-10 animate-in">

    <!-- Post Header -->
    <header class="space-y-4">
        <div class="flex flex-wrap items-center gap-3 label-mono text-on-surface-variant">
            <span class="text-primary">MISSION LOG</span>
            <span>&middot;</span>
            <time datetime="{{ date | date('yyyy-MM-dd') }}">{{ date | date("yyyy.MM.dd") }}</time>
            <span>&middot;</span>
            <span>{{ readingInfo.minutes or '5' }} min read</span>
            {% if tags %}
            <span>&middot;</span>
            {% for tag in tags %}
            <span class="text-tertiary">{{ tag }}</span>{% if not loop.last %}, {% endif %}
            {% endfor %}
            {% endif %}
        </div>

        {% if summary %}
        <p class="text-on-surface-variant text-lg leading-relaxed max-w-2xl">
            {{ summary }}
        </p>
        {% endif %}
    </header>

    <!-- Post Content -->
    <div class="prose prose-lg max-w-none">
        {{ content | safe }}
    </div>

    <!-- Post Footer -->
    <footer class="hud-platform rounded-hud p-6 space-y-4">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <a href="/blog/" class="btn-tertiary">&larr; Back to Mission Logs</a>
            <div class="label-mono text-on-surface-variant">
                Logged: {{ date | date("HUMAN_DATE") }}
            </div>
            <div class="flex gap-4">
                <a href="https://github.com/toasterson" class="btn-tertiary" target="_blank" rel="noopener">GitHub</a>
                <a href="https://chaos.social/@Toasterson" class="btn-tertiary" target="_blank" rel="noopener">Share</a>
            </div>
        </div>
        <p class="label-mono text-on-surface-variant text-center pt-2">
            End of transmission. May your code compile and your deployments be swift.
        </p>
    </footer>

</article>
