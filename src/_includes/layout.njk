<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} — {% endif %}Toasty's Blog // Toasty's Terminal</title>
    <meta name="description" content="{{ description or 'Systems engineering, Rust development, and Unix infrastructure by Till Wegmüller (@toasterson)' }}">

    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="alternate" type="application/rss+xml" title="Toasty's Terminal Feed" href="/feed.xml">

    {% if twitch %}
    <script src="https://embed.twitch.tv/embed/v1.js"></script>
    {% endif %}

    <script src="/js/terminal-effects.js" defer></script>
</head>
<body class="min-h-screen flex flex-col">

    <!-- ═══ HUD Navigation Bar ═══ -->
    <header class="nav-bar sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">

            <!-- Left: System ID -->
            <a href="/" class="flex items-center gap-3 group">
                <span class="status-dot"></span>
                <span class="font-grotesk font-bold text-on-surface text-sm tracking-wider uppercase group-hover:text-primary transition-colors">
                    Toasty's Blog
                </span>
            </a>

            <!-- Center: Navigation -->
            <nav class="hidden md:flex items-center gap-1">
                <a href="/" class="nav-link">Terminal</a>
                <a href="/blog/" class="nav-link">Mission_Logs</a>
                <a href="/about/" class="nav-link">Uplink</a>
                <a href="https://github.com/toasterson" class="nav-link" target="_blank" rel="noopener">GitHub</a>
                <a href="https://chaos.social/@Toasterson" class="nav-link" target="_blank" rel="noopener">Comms</a>
            </nav>

            <!-- Right: System Status -->
            <div class="hidden lg:flex items-center gap-4 label-mono text-on-surface-variant">
                <span>CPU <span id="cpu-usage" class="text-primary">12%</span></span>
                <span>MEM <span id="mem-usage" class="text-secondary">4.8GB</span></span>
                <span id="hud-clock" class="text-on-surface-variant"></span>
            </div>

            <!-- Mobile Menu Toggle -->
            <button id="mobile-menu-toggle" class="md:hidden text-on-surface-variant p-2" aria-label="Toggle navigation">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                    <line x1="3" y1="5" x2="17" y2="5"/>
                    <line x1="3" y1="10" x2="17" y2="10"/>
                    <line x1="3" y1="15" x2="17" y2="15"/>
                </svg>
            </button>
        </div>

        <!-- Mobile Navigation -->
        <nav id="mobile-menu" class="md:hidden hidden px-6 pb-4">
            <div class="flex flex-col gap-1 bg-surface-low rounded-hud p-3">
                <a href="/" class="nav-link">Terminal</a>
                <a href="/blog/" class="nav-link">Mission_Logs</a>
                <a href="/about/" class="nav-link">Uplink</a>
                <a href="https://github.com/toasterson" class="nav-link" target="_blank" rel="noopener">GitHub</a>
                <a href="https://chaos.social/@Toasterson" class="nav-link" target="_blank" rel="noopener">Comms</a>
            </div>
        </nav>
    </header>

    <!-- ═══ Main Content ═══ -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-12">
        {{ content | safe }}
    </main>

    <!-- ═══ Footer ═══ -->
    <footer class="site-footer">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="label-mono text-on-surface-variant">
                    &copy; {{ "now" | date("yyyy") }} Till Wegm&uuml;ller &middot; Built with cheekyness and pipes
                </div>
                <div class="flex items-center gap-6 label-mono">
                    <span class="text-primary">SYS: ONLINE</span>
                    <span class="text-on-surface-variant">LOC: Sol-3/Europe</span>
                    <a href="/feed.xml" class="text-secondary hover:text-primary transition-colors">RSS</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // HUD Clock
        function updateClock() {
            const el = document.getElementById('hud-clock');
            if (el) {
                const now = new Date();
                el.textContent = now.toISOString().slice(0, 19).replace('T', ' ');
            }
        }
        updateClock();
        setInterval(updateClock, 1000);

        // Mobile menu
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (toggle && menu) {
            toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
        }
    </script>
</body>
</html>
